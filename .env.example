# Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key

# Deribit Testnet
DERIBIT_TESTNET_API_KEY=your-deribit-testnet-api-key
DERIBIT_TESTNET_SECRET=your-deribit-testnet-secret

# Trading config
SYMBOL=BTCUSDT #ETHUSDT
TIMEFRAME=1h #1h
LOOKBACK_BARS=100
ATR_LENGTH=14
ATR_MULTIPLIER=1.5
FORECAST_CANDLES=3

# Position sizing
NUM_SYMBOLS=2
MAX_CONCURRENT_POSITIONS=3
MAX_POSITION_PCT=0.5
MIN_POSITION_USD=20
ACCOUNT_BALANCE=1000

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=quantagent
