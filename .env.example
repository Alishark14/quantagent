# ===== SECRETS (required) =====
# These are the ONLY values that belong in .env.
# All trading parameters come from the dashboard database or CLI arguments.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ===== Exchange Credentials =====
# dYdX v4 (wallet-based auth — mnemonic is your signing key)
DYDX_MNEMONIC=your 24 word mnemonic phrase here
DYDX_ADDRESS=dydx1youraddresshere

# Deribit (API key auth — create at test.deribit.com → Account → API Keys)
DERIBIT_TESTNET_API_KEY=your-key
DERIBIT_TESTNET_SECRET=your-secret

# Hyperliquid (wallet-based auth — use API wallet, NOT main wallet private key)
# Create an API wallet at app.hyperliquid.xyz → Settings → API
HYPERLIQUID_WALLET_ADDRESS=0xYourMainWalletAddress
HYPERLIQUID_PRIVATE_KEY=YourAPIWalletPrivateKeyHere

# ===== Observability (optional) =====
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_your-langsmith-key
LANGCHAIN_PROJECT=quantagent
