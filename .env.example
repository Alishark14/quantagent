# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Exchange selection ("deribit" or "dydx")
EXCHANGE=deribit
EXCHANGE_TESTNET=true

# Deribit Testnet (https://test.deribit.com)
# Account > API Keys > Create new key (enable "trade" scope)
DERIBIT_TESTNET_API_KEY=your_deribit_testnet_api_key
DERIBIT_TESTNET_SECRET=your_deribit_testnet_secret

# dYdX v4 Testnet (https://v4.testnet.dydx.exchange)
# Connect wallet → Settings → Export mnemonic
DYDX_MNEMONIC=your 24 word mnemonic phrase here
DYDX_ADDRESS=dydx1yourtestnetaddresshere

# Trading
SYMBOL=BTCUSDT
TIMEFRAME=1h
LOOKBACK_BARS=100

# Data fetching exchange (public OHLC, no auth needed)
DATA_EXCHANGE=bybit

# Risk
ATR_LENGTH=14
ATR_MULTIPLIER=1.5
FORECAST_CANDLES=3

# LangSmith tracing (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=quantagent
# LANGCHAIN_API_KEY=your_langsmith_api_key
